# =============================================================================
# Blog System — environment variable template
# Copy to apps/web/.env.local (for Next.js + Drizzle) and edit with real values.
# Copy EXPO_PUBLIC_* values to apps/mobile/.env.local for the mobile app.
# Never commit real values.
# =============================================================================

# --- Database (Neon serverless Postgres) ---
DATABASE_URL=postgresql://user:password@host.neon.tech/dbname?sslmode=require

# --- Auth ---
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-me-with-32-byte-random-hex

# --- Cloudflare R2 (S3-compatible) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
R2_PUBLIC_BASE_URL=https://pub-<hash>.r2.dev

# --- Mobile (exposed to the client bundle, must be EXPO_PUBLIC_*) ---
EXPO_PUBLIC_API_URL=http://localhost:3000
